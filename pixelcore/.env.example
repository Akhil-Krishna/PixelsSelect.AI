# ─────────────────────────────────────────────────────────────────────────────
# PixelSelect — environment configuration
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Pixels-Select AI Interview"
APP_ENV=development          # development | staging | production
DEBUG=true
FRONTEND_URL=http://localhost:3000
UPLOADS_DIR=uploads
SEED_DEMO_DATA=true          # seed 4 demo users on first DEBUG start

# ── Database (PostgreSQL via Docker) ─────────────────────────────────────────
DATABASE_URL=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=3600

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: groq | openai | ollama | mock
LLM_PROVIDER=groq

# Groq (fast, free tier available)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=30

# OpenAI or any OpenAI-compatible local server
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=30

# Ollama (local, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=120

# Local OpenAI-compatible model server (llama.cpp, LM Studio, vLLM, etc.)
LOCAL_MODEL_SERVER_ENABLED=false
LOCAL_MODEL_SERVER_URL=http://localhost:8080/v1

# ── Vision ────────────────────────────────────────────────────────────────────
# Options: deepface | mock
VISION_PROVIDER=deepface
ENABLE_VISION_WARMUP=true
VISION_PERSIST_ENABLED=true
VISION_LOG_SAMPLE_EVERY_N=10

# ── Speech-to-Text ────────────────────────────────────────────────────────────
# Options: groq | local
STT_PROVIDER=groq
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_STT_TIMEOUT=30

# Local faster-whisper settings (used when STT_PROVIDER=local)
STT_MODEL=base.en
STT_DEVICE=cpu
STT_COMPUTE=int8
STT_BEAM_SIZE=3
STT_VAD_FILTER=true
STT_VAD_MIN_SILENCE_MS=300

# ── Email ─────────────────────────────────────────────────────────────────────
# Options: log | sendgrid
EMAIL_PROVIDER=log
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
EMAIL_FROM=noreply@pixelselect.ai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_SOCKET_TIMEOUT_SECONDS=2
REDIS_HEALTH_TIMEOUT_SECONDS=3

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_ENABLED=false
CELERY_REALTIME_ENABLED=false
CELERY_BACKGROUND_ENABLED=false
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_WAIT_TIMEOUT_SECONDS=25
CELERY_ENQUEUE_TIMEOUT_SECONDS=3
CELERY_SOFT_TIME_LIMIT_SECONDS=90
CELERY_TIME_LIMIT_SECONDS=120
CELERY_FALLBACK_COOLDOWN_SECONDS=30

# ── Feature flags ─────────────────────────────────────────────────────────────
AI_LOCAL_FASTPATH_ENABLED=true
STT_LOCAL_FASTPATH_ENABLED=true
ENABLE_GLOBAL_ERROR_ENVELOPE=true
ENABLE_REQUEST_ID_MIDDLEWARE=true
ENABLE_IDEMPOTENCY=true

# ── WebRTC / Signalling ───────────────────────────────────────────────────────
# Options: auto | memory | redis
ROOM_BACKEND=memory
RTC_ROOM_CAPACITY=10
RTC_JOIN_RATE_LIMIT=5
RTC_JOIN_WINDOW_SECONDS=30
RTC_HEARTBEAT_SECONDS=15
RTC_STALE_PARTICIPANT_TTL_SECONDS=30

# ── Frontend WebSocket URL ───────────────────────────────────────────────────
# Required in production - the WebSocket endpoint for real-time communication
# Format: ws://localhost:8000 (development) or wss://your-backend-domain.com (production)
NEXT_PUBLIC_WS_URL=ws://localhost:8000
